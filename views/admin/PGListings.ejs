<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PG Listings</title>
    <link rel="stylesheet" href="/css/adminDashboard.css">
    <link rel="stylesheet" href="/css/card.css">
    
</head>
<body>
<div class="admin-layout">
    <%- include('../partials/adminSidebar') %>
    <main class="main-content">
        <div class="top-header">
            <div>
                <h1>PG Listings</h1>
                <p>Manage all PG properties.</p>
            </div>
            <button
                class="add-btn"
                onclick="window.location.href='/admin/addnewpg'"
            >
                + Add New PG
            </button>
        </div>
          <% if(successMessage){ %>
    <div class="success-alert">
        ✅ <%= successMessage %>
    </div>
<% } %>
        <div class="cards-grid">
            <% if(pgs && pgs.length > 0){ %>
                <% pgs.forEach(pg => { %>
                    <div class="card">
                        <div class="card-img-wrap">
                            <img
                                src="<%= pg.imageUrl %>"
                                alt="<%= pg.pgName %>"
                                loading="lazy"
                            >
                            <span class="badge-type badge-premium">
                                <%= pg.pgType %>
                            </span>
                            <span class="badge-gender badge-unisex">
                                <%= pg.gender.toUpperCase() %>
                            </span>
                        </div>
                     <div class="card-body">
                            <div class="card-title">
                                <%= pg.pgName %>
                            </div>
                            <div class="card-location">
                                📍 <%= pg.area %>, <%= pg.city %>, <%= pg.state %>
                            </div>
                            <div class="tags">
                                <% if(pg.amenities && pg.amenities.length > 0){ %>
                                    <% pg.amenities.forEach(amenity => { %>
                                        <span class="tag">
                                            <%= amenity %>
                                        </span>
                                    <% }) %>
                                <% } %>
                            </div>
                            <div class="card-footer">
                                <div class="price-wrap">
                                    <span class="price-label">
                                        Starts at
                                    </span>
                                    <span class="price">
                                        ₹<%= pg.rent %>
                                        <span>/mo</span>
                                    </span>
                             </div>
                        <div class="admin-actions">
                                    <a
                                        href="/admin/editpg/<%= pg._id %>"
                                        class="btn-edit"
                                    >
                                        Edit PG
                                    </a>
                    <form
                            action="/admin/deletepg/<%= pg._id %>"
                            method="POST"
                            class="delete-form"
                          >
                     <button
                            type="button"
                           class="btn-delete"
                            onclick="openDeleteModal(this)"
                        >
                  Delete PG
                </button>
                </form>

                                </div>

                            </div>

                        </div>

                    </div>
                <% }) %>
            <% } else { %>
                <h2 style="text-align:center; margin-top:50px;">
                    No PG Listings Available
                </h2>
            <% } %>
        </div>
    </main>
</div>
<div id="deleteModal" class="modal">
    <div class="modal-content">
        <h3>Delete PG</h3>
        <p>Are you sure you want to delete this PG?</p>
        <div class="modal-actions">
            <button
                class="btn-no"
                onclick="closeDeleteModal()"
            >
                No
            </button>
            <button
                class="btn-yes"
                onclick="confirmDelete()"
            >
                Yes
            </button>
        </div>
    </div>

</div>
<script>
    setTimeout(() => {
        const alertBox =
            document.querySelector('.success-alert');
        if(alertBox){
            alertBox.style.transition =
                'opacity .5s ease';
            alertBox.style.opacity = '0';
            setTimeout(() => {
                alertBox.remove();

            }, 500);
        }

    }, 3000);
    let selectedForm = null;
    function openDeleteModal(button){
        selectedForm = button.closest('.delete-form');
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDeleteModal(){
        document.getElementById('deleteModal').style.display = 'none';
        selectedForm = null;
    }
    function confirmDelete(){
        if(selectedForm){
            selectedForm.submit();
        }
    }
</script>
</body>
</html>