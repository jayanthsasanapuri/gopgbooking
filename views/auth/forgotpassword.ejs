<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - GoPGBooking</title>
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>
<div class="auth-page">
    <!-- Background Blobs -->
    <div class="auth-blob auth-blob-1"></div>
    <div class="auth-blob auth-blob-2"></div>
    <div class="auth-card">
        <!-- Logo -->
        <div class="auth-logo">
            <h1>
                <span class="green">gopg</span>booking
            </h1>
        </div>
        <h2 class="auth-title">
            Forgot Password
        </h2>
        <p class="auth-subtitle">
            Enter your registered email address.
            We'll send a One-Time Password (OTP) to reset your password.
        </p>
          <% if(error){ %>
                <div class="auth-error">
                    <%= error %>
                </div>
            <% } %>
        <form
            class="auth-form"
            action="/forgot-password"
            method="POST"
        >
            <div class="form-group">
                <label for="email">
                    Registered Email
                </label>
                <div class="input-wrap">
                    <span class="input-icon">
                        ✉️
                    </span>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="Enter your registered email"
                        autocomplete="email"
                        required
                    >
                </div>
            </div>
            <% if(success){ %>
                <div class="auth-success">
                    <%= success %>
                </div>
            <% } %>
            <button
                type="submit"
                class="auth-btn"
            >
                Send OTP
            </button>
        </form>
        <p class="auth-switch">
            Remember your password?
            <a
                href="/login"
                class="auth-link"
            >

                Back to Login

            </a>
        </p>
    </div>
</div>
</body>
</html>